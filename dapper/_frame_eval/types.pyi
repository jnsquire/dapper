import contextvars
from types import CodeType
from types import FrameType
from typing import Any

from typing_extensions import TypeAlias

FrameStats: TypeAlias = dict[str, int | float | bool]
BreakpointLines: TypeAlias = set[int]

class _FrameEvalModuleState:
    active: bool
    thread_info_var: contextvars.ContextVar[ThreadInfo | None]

    def enable(self) -> None: ...
    def disable(self) -> None: ...
    def get_thread_info(self) -> ThreadInfo: ...
    def clear_thread_local_info(self) -> None: ...
    def get_stats(self) -> FrameStats: ...

_state: _FrameEvalModuleState

class ThreadInfo:
    inside_frame_eval: int
    fully_initialized: bool
    is_debugger_internal_thread: bool
    thread_trace_func: Any | None
    additional_info: Any | None
    recursion_depth: int
    skip_all_frames: bool
    step_mode: bool

    def __init__(self) -> None: ...
    def enter_frame_eval(self) -> None: ...
    def exit_frame_eval(self) -> None: ...
    def should_skip_frame(self, frame: FrameType) -> bool: ...

class FuncCodeInfo:
    co_filename: bytes
    real_path: str
    always_skip_code: bool
    breakpoint_found: bool
    new_code: CodeType | None
    breakpoints_mtime: float
    breakpoint_lines: BreakpointLines
    last_check_time: float
    is_valid: bool

    def __init__(self) -> None: ...
    def update_breakpoint_info(self, code_obj: CodeType) -> None: ...

def get_func_code_info(frame_obj: FrameType, code_obj: CodeType | object) -> FuncCodeInfo: ...

# Backward-compatible convenience aliases that delegate to _state
def get_thread_info() -> ThreadInfo: ...
def frame_eval_func() -> None: ...
def stop_frame_eval() -> None: ...
def clear_thread_local_info() -> None: ...
def get_frame_eval_stats() -> FrameStats: ...
def install_eval_frame_hook() -> bool: ...
def uninstall_eval_frame_hook() -> bool: ...
def get_eval_frame_hook_status() -> dict[str, Any]: ...
def get_frame_eval_capabilities() -> dict[str, Any]: ...
def mark_thread_as_debugger_internal() -> None: ...
def unmark_thread_as_debugger_internal() -> None: ...
def set_thread_skip_all(skip: bool) -> None: ...
def _collect_code_lines(code_obj: CodeType) -> set[int]: ...
def _clear_thread_trace_func() -> None: ...
def _dispatch_eval_frame_entry_trace(frame_obj: FrameType) -> bool: ...
def _dispatch_eval_frame_return_trace(frame_obj: FrameType, arg: Any = None) -> bool: ...
def _dispatch_trace_callback(
    frame_obj: FrameType, event: str = "line", arg: Any = None
) -> bool: ...
def _get_code_extra_metadata(code_obj: CodeType) -> Any: ...
def _get_current_eval_frame_address() -> int: ...
def _get_modified_code_for_evaluation(code_obj: CodeType) -> CodeType | None: ...
def _set_thread_trace_func(trace_func: Any) -> None: ...
def _store_code_extra_metadata(code_obj: CodeType, metadata: Any) -> bool: ...
def _store_modified_code_for_evaluation(
    original_code: CodeType,
    modified_code: CodeType,
    breakpoint_lines: Any = None,
) -> bool: ...
def _should_trace_code_for_eval_frame(code_obj: CodeType, lineno: int) -> bool: ...
def _should_trace_code_for_eval_frame_with_frame(
    code_obj: CodeType,
    lineno: int,
    frame_obj: FrameType | None = None,
) -> bool: ...
def _clear_code_extra_metadata(code_obj: CodeType) -> bool: ...
